{
  "display_information": {
    "name": "CrewAI PRD Planner",
    "description": "AI-powered product feature planner that generates comprehensive PRDs via Slack.",
    "background_color": "#1a73e8"
  },
  "features": {
    "bot_user": {
      "display_name": "crewai-prd-bot",
      "always_online": true
    },
    "app_home": {
      "home_tab_enabled": false,
      "messages_tab_enabled": true,
      "messages_tab_read_only_enabled": false
    }
  },
  "oauth_config": {
    "redirect_urls": [
      "https://YOUR_NGROK_DOMAIN/slack/oauth/callback"
    ],
    "scopes": {
      "bot": [
        "chat:write",
        "chat:write.public",
        "channels:history",
        "channels:read",
        "channels:join",
        "groups:history",
        "groups:read",
        "im:history",
        "im:read",
        "mpim:history",
        "mpim:read",
        "app_mentions:read",
        "reactions:write",
        "reactions:read",
        "users:read"
      ]
    },
    "token_management_enabled": true
  },
  "settings": {
    "interactivity": {
      "is_enabled": true,
      "request_url": "https://YOUR_NGROK_DOMAIN/slack/interactions"
    },
    "event_subscriptions": {
      "request_url": "https://YOUR_NGROK_DOMAIN/slack/events",
      "bot_events": [
        "app_mention",
        "member_joined_channel",
        "message.channels",
        "message.groups"
      ]
    },
    "token_rotation_enabled": true,
    "socket_mode_enabled": false,
    "org_deploy_enabled": false,
    "is_hosted": false
  }
}

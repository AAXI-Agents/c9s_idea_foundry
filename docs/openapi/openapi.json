{
  "openapi": "3.1.0",
  "info": {
    "title": "CrewAI Product Feature Planner API",
    "description": "HTTP interface for the CrewAI PRD generation flow. The flow uses a two-phase architecture: Phase 1 iterates an Executive Summary, Phase 2 auto-iterates 9 remaining PRD sections with configurable min/max iterations. Includes degenerate output guards, error-to-paused recovery, and resume-from-last-iteration support.",
    "version": "0.2.0"
  },
  "paths": {
    "/health": {
      "$ref": "./paths/health.json"
    },
    "/flow/runs": {
      "$ref": "./paths/flow/runs.json"
    },
    "/flow/runs/{run_id}": {
      "$ref": "./paths/flow/runs_{run_id}.json"
    },
    "/flow/prd/kickoff": {
      "$ref": "./paths/flow/prd_kickoff.json"
    },
    "/flow/prd/approve": {
      "$ref": "./paths/flow/prd_approve.json"
    },
    "/flow/prd/pause": {
      "$ref": "./paths/flow/prd_pause.json"
    },
    "/flow/prd/resumable": {
      "$ref": "./paths/flow/prd_resumable.json"
    },
    "/flow/prd/resume": {
      "$ref": "./paths/flow/prd_resume.json"
    },
    "/flow/jobs": {
      "$ref": "./paths/flow/jobs.json"
    },
    "/flow/jobs/{job_id}": {
      "$ref": "./paths/flow/jobs_{job_id}.json"
    }
  },
  "components": {
    "schemas": {
      "HTTPValidationError": {
        "properties": {
          "detail": {
            "items": {
              "$ref": "#/components/schemas/ValidationError"
            },
            "type": "array",
            "title": "Detail"
          }
        },
        "type": "object",
        "title": "HTTPValidationError"
      },
      "PRDKickoffRequest": {
        "properties": {
          "idea": {
            "type": "string",
            "minLength": 1,
            "title": "Idea",
            "description": "The product feature idea to build a PRD for."
          },
          "auto_approve": {
            "type": "boolean",
            "default": false,
            "title": "Auto Approve",
            "description": "When true, the flow runs end-to-end without pausing for manual approval at each section (same behaviour as the CLI). Sections auto-iterate and are auto-approved when the critique contains SECTION_READY. The POST /flow/prd/approve endpoint is not needed — poll GET /flow/runs/{run_id} for progress instead."
          }
        },
        "type": "object",
        "required": [
          "idea"
        ],
        "title": "PRDKickoffRequest",
        "description": "Request body for POST /flow/prd/kickoff."
      },
      "PRDKickoffResponse": {
        "properties": {
          "run_id": {
            "type": "string",
            "title": "Run Id",
            "description": "Unique identifier for this flow run."
          },
          "flow_name": {
            "type": "string",
            "title": "Flow Name",
            "description": "Name of the flow."
          },
          "status": {
            "type": "string",
            "title": "Status",
            "description": "Current status of the run."
          },
          "message": {
            "type": "string",
            "title": "Message",
            "description": "Human-readable status message."
          }
        },
        "type": "object",
        "required": [
          "run_id",
          "status",
          "message"
        ],
        "title": "PRDKickoffResponse",
        "description": "Response for POST /flow/prd/kickoff. Returned when a new PRD flow is accepted. The flow runs in the background through Idea Refinement, Requirements Breakdown, Phase 1 (Executive Summary iteration), and Phase 2 (9-section auto-iterate)."
      },
      "PRDApproveRequest": {
        "properties": {
          "run_id": {
            "type": "string",
            "title": "Run Id",
            "description": "The run to approve or continue."
          },
          "approve": {
            "type": "boolean",
            "title": "Approve",
            "description": "True to approve the current section, False to keep refining."
          },
          "feedback": {
            "type": [
              "string",
              "null"
            ],
            "title": "Feedback",
            "description": "Optional critique feedback from the user."
          },
          "selected_agent": {
            "type": [
              "string",
              "null"
            ],
            "title": "Selected Agent",
            "description": "Which agent's result to use (e.g. 'openai_pm'). Required when multiple agents produced results."
          }
        },
        "type": "object",
        "required": [
          "run_id",
          "approve"
        ],
        "title": "PRDApproveRequest",
        "description": "Request body for POST /flow/prd/approve."
      },
      "PRDActionResponse": {
        "properties": {
          "run_id": {
            "type": "string",
            "title": "Run Id",
            "description": "The run this action was applied to."
          },
          "action": {
            "type": "string",
            "title": "Action",
            "description": "The action that was taken."
          },
          "section": {
            "type": "string",
            "title": "Section",
            "description": "The section key the action was applied to."
          },
          "current_step": {
            "type": ["integer", "null"],
            "title": "Current Step",
            "description": "1-based step number of the current section."
          },
          "sections_approved": {
            "type": ["integer", "null"],
            "title": "Sections Approved",
            "description": "Number of sections approved so far."
          },
          "sections_total": {
            "type": ["integer", "null"],
            "title": "Sections Total",
            "description": "Total number of sections in the PRD."
          },
          "is_final_section": {
            "type": "boolean",
            "title": "Is Final Section",
            "description": "True when this approval completed the last section."
          },
          "active_agents": {
            "items": { "type": "string" },
            "type": "array",
            "title": "Active Agents",
            "description": "Agent identifiers currently participating in the flow (e.g. ['openai_pm'])."
          },
          "dropped_agents": {
            "items": { "type": "string" },
            "type": "array",
            "title": "Dropped Agents",
            "description": "Agent identifiers removed from the flow after failing during parallel drafting."
          },
          "agent_errors": {
            "type": "object",
            "additionalProperties": { "type": "string" },
            "title": "Agent Errors",
            "description": "Map of dropped agent name to its error message."
          },
          "message": {
            "type": "string",
            "title": "Message",
            "description": "Human-readable result message."
          }
        },
        "type": "object",
        "required": [
          "run_id",
          "action",
          "message"
        ],
        "title": "PRDActionResponse",
        "description": "Response for approval, pause, and feedback actions."
      },
      "PRDPauseRequest": {
        "properties": {
          "run_id": {
            "type": "string",
            "title": "Run Id",
            "description": "The run to pause."
          }
        },
        "type": "object",
        "required": [
          "run_id"
        ],
        "title": "PRDPauseRequest",
        "description": "Request body for POST /flow/prd/pause."
      },
      "PRDResumeRequest": {
        "properties": {
          "run_id": {
            "type": "string",
            "title": "Run Id",
            "description": "The run_id of an unfinalized working idea to resume."
          },
          "auto_approve": {
            "type": "boolean",
            "default": false,
            "title": "Auto Approve",
            "description": "When true, the resumed flow runs end-to-end without pausing for manual approval at each section. Poll GET /flow/runs/{run_id} for progress instead of calling POST /flow/prd/approve."
          }
        },
        "type": "object",
        "required": [
          "run_id"
        ],
        "title": "PRDResumeRequest",
        "description": "Request body for POST /flow/prd/resume."
      },
      "PRDResumeResponse": {
        "properties": {
          "run_id": {
            "type": "string",
            "title": "Run Id",
            "description": "The resumed run identifier."
          },
          "flow_name": {
            "type": "string",
            "title": "Flow Name",
            "description": "Name of the flow."
          },
          "status": {
            "type": "string",
            "title": "Status",
            "description": "Current status after resuming."
          },
          "sections_approved": {
            "type": "integer",
            "title": "Sections Approved",
            "description": "Number of sections already approved."
          },
          "sections_total": {
            "type": "integer",
            "title": "Sections Total",
            "description": "Total number of PRD sections."
          },
          "next_section": {
            "type": [
              "string",
              "null"
            ],
            "title": "Next Section",
            "description": "Key of the next section to iterate."
          },
          "next_step": {
            "type": [
              "integer",
              "null"
            ],
            "title": "Next Step",
            "description": "1-based step number of the next section."
          },
          "message": {
            "type": "string",
            "title": "Message",
            "description": "Human-readable status message."
          }
        },
        "type": "object",
        "required": [
          "run_id",
          "status",
          "message"
        ],
        "title": "PRDResumeResponse",
        "description": "Response for POST /flow/prd/resume. Sections with existing content skip the draft step and resume into the critique/refine loop. Degenerate content from a previous crash is cleaned up automatically."
      },
      "PRDSectionDetail": {
        "properties": {
          "key": {
            "type": "string",
            "title": "Key",
            "description": "Section identifier slug."
          },
          "title": {
            "type": "string",
            "title": "Title",
            "description": "Human-readable section title."
          },
          "step": {
            "type": "integer",
            "title": "Step",
            "description": "1-based step number in the PRD workflow."
          },
          "content": {
            "type": "string",
            "title": "Content",
            "description": "Current markdown content."
          },
          "critique": {
            "type": "string",
            "title": "Critique",
            "description": "Latest critique text."
          },
          "iteration": {
            "type": "integer",
            "title": "Iteration",
            "description": "Section iteration count."
          },
          "updated_date": {
            "type": "string",
            "title": "Updated Date",
            "description": "ISO-8601 timestamp of the last update to this section."
          },
          "is_approved": {
            "type": "boolean",
            "title": "Is Approved",
            "description": "Whether this section is approved."
          },
          "agent_results": {
            "type": "object",
            "additionalProperties": { "type": "string" },
            "title": "Agent Results",
            "description": "Per-agent draft results. Keys are agent identifiers (e.g. 'openai_pm'), values are the markdown content each agent produced."
          },
          "selected_agent": {
            "type": "string",
            "title": "Selected Agent",
            "description": "Which agent's result was selected by the user."
          }
        },
        "type": "object",
        "required": [
          "key",
          "title"
        ],
        "title": "PRDSectionDetail"
      },
      "PRDDraftDetail": {
        "properties": {
          "sections": {
            "items": {
              "$ref": "#/components/schemas/PRDSectionDetail"
            },
            "type": "array",
            "title": "Sections",
            "description": "Ordered list of PRD sections with their current state."
          },
          "all_approved": {
            "type": "boolean",
            "title": "All Approved",
            "description": "True when every section has been approved."
          }
        },
        "type": "object",
        "required": [
          "sections",
          "all_approved"
        ],
        "title": "PRDDraftDetail"
      },
      "PRDRunStatusResponse": {
        "properties": {
          "run_id": {
            "type": "string",
            "title": "Run Id",
            "description": "Unique run identifier."
          },
          "flow_name": {
            "type": "string",
            "title": "Flow Name",
            "description": "Name of the flow."
          },
          "status": {
            "type": "string",
            "title": "Status",
            "description": "Current lifecycle status."
          },
          "iteration": {
            "type": "integer",
            "title": "Iteration",
            "description": "Total iteration count across all sections. Phase 1 (Executive Summary) iterates >= PRD_EXEC_RESUME_THRESHOLD times, Phase 2 sections each iterate between PRD_SECTION_MIN_ITERATIONS and PRD_SECTION_MAX_ITERATIONS."
          },
          "created_at": {
            "type": "string",
            "title": "Created At",
            "description": "ISO-8601 creation timestamp."
          },
          "update_date": {
            "type": [
              "string",
              "null"
            ],
            "title": "Update Date",
            "description": "ISO-8601 timestamp of the last update."
          },
          "completed_at": {
            "type": [
              "string",
              "null"
            ],
            "title": "Completed At",
            "description": "ISO-8601 timestamp when the run was completed."
          },
          "result": {
            "type": [
              "string",
              "null"
            ],
            "title": "Result",
            "description": "Final result when completed."
          },
          "error": {
            "type": [
              "string",
              "null"
            ],
            "title": "Error",
            "description": "Error message if the run was paused due to an error. Prefixed with an error code: BILLING_ERROR, LLM_ERROR, or INTERNAL_ERROR. Errors always result in status='paused' (never 'failed')."
          },
          "current_section_key": {
            "type": "string",
            "title": "Current Section Key",
            "description": "Key of the section currently being iterated."
          },
          "current_step": {
            "type": "integer",
            "title": "Current Step",
            "description": "1-based step number of the current section."
          },
          "sections_approved": {
            "type": "integer",
            "title": "Sections Approved",
            "description": "Number of approved sections."
          },
          "sections_total": {
            "type": "integer",
            "title": "Sections Total",
            "description": "Total number of PRD sections."
          },
          "active_agents": {
            "items": { "type": "string" },
            "type": "array",
            "title": "Active Agents",
            "description": "Agent identifiers currently participating in the flow."
          },
          "dropped_agents": {
            "items": { "type": "string" },
            "type": "array",
            "title": "Dropped Agents",
            "description": "Agent identifiers removed after failing during parallel drafting."
          },
          "agent_errors": {
            "type": "object",
            "additionalProperties": { "type": "string" },
            "title": "Agent Errors",
            "description": "Map of dropped agent name to its error message."
          },
          "original_idea": {
            "type": "string",
            "title": "Original Idea",
            "description": "The raw idea before the Idea Refinement agent enriched it. Empty when refinement was skipped.",
            "default": ""
          },
          "idea_refined": {
            "type": "boolean",
            "title": "Idea Refined",
            "description": "Whether the idea was refined by the Idea Refinement agent.",
            "default": false
          },
          "current_draft": {
            "$ref": "#/components/schemas/PRDDraftDetail"
          }
        },
        "type": "object",
        "required": [
          "run_id",
          "flow_name",
          "status",
          "iteration",
          "created_at",
          "current_section_key",
          "current_draft"
        ],
        "title": "PRDRunStatusResponse"
      },
      "PRDResumableRun": {
        "properties": {
          "run_id": {
            "type": "string",
            "title": "Run Id",
            "description": "Unique run identifier."
          },
          "idea": {
            "type": "string",
            "title": "Idea",
            "description": "The feature idea text."
          },
          "iteration": {
            "type": "integer",
            "title": "Iteration",
            "description": "Last iteration number."
          },
          "created_at": {
            "type": [
              "string",
              "null"
            ],
            "title": "Created At",
            "description": "ISO-8601 timestamp of the last activity."
          },
          "sections": {
            "items": {
              "type": "string"
            },
            "type": "array",
            "title": "Sections",
            "description": "Section keys that have draft content."
          }
        },
        "type": "object",
        "required": [
          "run_id",
          "idea",
          "iteration",
          "sections"
        ],
        "title": "PRDResumableRun"
      },
      "PRDResumableListResponse": {
        "properties": {
          "count": {
            "type": "integer",
            "title": "Count",
            "description": "Number of resumable runs."
          },
          "runs": {
            "items": {
              "$ref": "#/components/schemas/PRDResumableRun"
            },
            "type": "array",
            "title": "Runs",
            "description": "List of resumable runs."
          }
        },
        "type": "object",
        "required": [
          "count",
          "runs"
        ],
        "title": "PRDResumableListResponse"
      },
      "JobDetail": {
        "properties": {
          "job_id": {
            "type": "string",
            "title": "Job Id",
            "description": "Unique job identifier (same as run_id)."
          },
          "flow_name": {
            "type": "string",
            "title": "Flow Name",
            "description": "Name of the flow (e.g. 'prd')."
          },
          "idea": {
            "type": "string",
            "title": "Idea",
            "description": "The feature idea / input text."
          },
          "status": {
            "type": "string",
            "title": "Status",
            "description": "Job lifecycle status: queued, running, awaiting_approval, paused, or completed. Errors result in 'paused' (not 'failed'), allowing runs to be resumed."
          },
          "error": {
            "type": [
              "string",
              "null"
            ],
            "title": "Error",
            "description": "Error message when the job was paused due to an error (LLM, billing, or internal)."
          },
          "queued_at": {
            "type": [
              "string",
              "null"
            ],
            "title": "Queued At",
            "description": "ISO-8601 timestamp when the job was created."
          },
          "started_at": {
            "type": [
              "string",
              "null"
            ],
            "title": "Started At",
            "description": "ISO-8601 timestamp when execution began."
          },
          "completed_at": {
            "type": [
              "string",
              "null"
            ],
            "title": "Completed At",
            "description": "ISO-8601 timestamp when the job reached a terminal state."
          },
          "queue_time_ms": {
            "type": [
              "integer",
              "null"
            ],
            "title": "Queue Time Ms",
            "description": "Time spent in queue in milliseconds."
          },
          "queue_time_human": {
            "type": [
              "string",
              "null"
            ],
            "title": "Queue Time Human",
            "description": "Queue duration in human-readable form."
          },
          "running_time_ms": {
            "type": [
              "integer",
              "null"
            ],
            "title": "Running Time Ms",
            "description": "Time spent running in milliseconds."
          },
          "running_time_human": {
            "type": [
              "string",
              "null"
            ],
            "title": "Running Time Human",
            "description": "Running duration in human-readable form."
          },
          "updated_at": {
            "type": [
              "string",
              "null"
            ],
            "title": "Updated At",
            "description": "ISO-8601 timestamp of last update."
          }
        },
        "type": "object",
        "required": [
          "job_id",
          "flow_name",
          "status"
        ],
        "title": "JobDetail"
      },
      "JobListResponse": {
        "properties": {
          "count": {
            "type": "integer",
            "title": "Count",
            "description": "Number of jobs returned."
          },
          "jobs": {
            "items": {
              "$ref": "#/components/schemas/JobDetail"
            },
            "type": "array",
            "title": "Jobs",
            "description": "List of job records."
          }
        },
        "type": "object",
        "required": [
          "count",
          "jobs"
        ],
        "title": "JobListResponse"
      },
      "ValidationError": {
        "properties": {
          "loc": {
            "items": {
              "anyOf": [
                {
                  "type": "string"
                },
                {
                  "type": "integer"
                }
              ]
            },
            "type": "array",
            "title": "Location"
          },
          "msg": {
            "type": "string",
            "title": "Message"
          },
          "type": {
            "type": "string",
            "title": "Error Type"
          },
          "input": {
            "title": "Input"
          },
          "ctx": {
            "type": "object",
            "title": "Context"
          }
        },
        "type": "object",
        "required": [
          "loc",
          "msg",
          "type"
        ],
        "title": "ValidationError"
      },
      "ErrorResponse": {
        "description": "Standard error envelope returned by all API endpoints for server-side or LLM errors.",
        "properties": {
          "error_code": {
            "type": "string",
            "title": "Error Code",
            "description": "Machine-readable error code. One of: LLM_ERROR, BILLING_ERROR, INTERNAL_ERROR.",
            "enum": ["LLM_ERROR", "BILLING_ERROR", "INTERNAL_ERROR"],
            "examples": ["LLM_ERROR"]
          },
          "message": {
            "type": "string",
            "title": "Message",
            "description": "Human-readable description of the error.",
            "examples": ["LLM timeout after 4 attempts"]
          },
          "run_id": {
            "type": ["string", "null"],
            "title": "Run Id",
            "description": "The run_id affected by this error, if applicable.",
            "examples": ["a1b2c3d4e5f6"]
          },
          "detail": {
            "type": ["string", "null"],
            "title": "Detail",
            "description": "Additional diagnostic detail (e.g. the original exception message)."
          }
        },
        "type": "object",
        "required": ["error_code", "message"],
        "title": "ErrorResponse"
      }
    }
  }
}

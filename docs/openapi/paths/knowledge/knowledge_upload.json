{
  "post": {
    "tags": [
      "Knowledge"
    ],
    "summary": "Upload a knowledge document",
    "description": "Multipart file upload. Max 25 MB. Triggers Content Reviewer asynchronously.",
    "operationId": "upload_knowledge_document_projects__project_id__knowledge_upload_post",
    "parameters": [
      {
        "name": "project_id",
        "in": "path",
        "required": true,
        "schema": {
          "type": "string",
          "title": "Project Id"
        }
      },
      {
        "name": "organization_id",
        "in": "query",
        "required": false,
        "schema": {
          "anyOf": [
            {
              "type": "string"
            },
            {
              "type": "null"
            }
          ],
          "title": "Organization Id"
        }
      }
    ],
    "requestBody": {
      "required": true,
      "content": {
        "multipart/form-data": {
          "schema": {
            "$ref": "#/components/schemas/Body_upload_knowledge_document_projects__project_id__knowledge_upload_post"
          }
        }
      }
    },
    "responses": {
      "201": {
        "description": "Document created, review in progress.",
        "content": {
          "application/json": {
            "schema": {
              "$ref": "#/components/schemas/KnowledgeDocCreated"
            }
          }
        }
      },
      "413": {
        "description": "File too large."
      },
      "422": {
        "description": "Validation Error",
        "content": {
          "application/json": {
            "schema": {
              "$ref": "#/components/schemas/HTTPValidationError"
            }
          }
        }
      }
    }
  }
}
{
  "get": {
    "tags": [
      "Code Repos"
    ],
    "summary": "GitHub OAuth callback",
    "description": "Handles the OAuth callback from GitHub. Exchanges code for token.",
    "operationId": "github_callback_auth_github_callback_get",
    "parameters": [

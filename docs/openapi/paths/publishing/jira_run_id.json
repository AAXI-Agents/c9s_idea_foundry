        "content": {
          "application/json": {
            "schema": {
              "$ref": "#/components/schemas/PublishingErrorResponse"
            }
          }
        }
      },
      "422": {
        "description": "Validation Error",
        "content": {
          "application/json": {
            "schema": {
              "$ref": "#/components/schemas/HTTPValidationError"
            }
          }
        }
      }
    }
  }

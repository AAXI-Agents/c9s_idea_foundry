{
  "post": {
    "tags": [
      "SSO"
    ],
    "summary": "Refresh SSO access token",
    "description": "Proxy a token-refresh request to the SSO server.\n\nExpects JSON body: ``{\"refresh_token\": \"...\"}``",
    "operationId": "sso_token_refresh_auth_sso_token_refresh_post",
    "responses": {
      "200": {
        "description": "New token pair returned",
        "content": {
          "application/json": {
            "schema": {}
          }
        }
      },
      "400": {
        "description": "Missing refresh_token"
      },
      "401": {
        "description": "Invalid or expired refresh token"
      },
      "502": {
        "description": "SSO server unreachable"
      }
    }
  }
}
{
  "get": {
    "tags": ["Health"],
    "summary": "Slack token rotation status",
    "operationId": "slack_token_status",
    "description": "Returns the current Slack token rotation state including token type, whether rotation is configured, time until expiry, last refresh timestamp, and the path to the persisted token store.\n\n**No secrets are exposed** — only metadata about token health.",
    "responses": {
      "200": {
        "description": "Token rotation diagnostics.",
        "content": {
          "application/json": {
            "schema": {
              "type": "object",
              "properties": {
                "token_type": {
                  "type": "string",
                  "description": "Token type: `rotating` or `static`.",
                  "example": "rotating"
                },
                "rotation_configured": {
                  "type": "boolean",
                  "description": "Whether token rotation is set up."
                },
                "expires_in_seconds": {
                  "type": "integer",
                  "description": "Seconds until the current token expires."
                },
                "last_refresh": {
                  "type": "string",
                  "description": "ISO-8601 timestamp of the last refresh."
                },
                "store_path": {
                  "type": "string",
                  "description": "Path to the persisted token file."
                }
              }
            },
            "example": {
              "token_type": "rotating",
              "rotation_configured": true,
              "expires_in_seconds": 39600,
              "last_refresh": "2026-02-25T10:00:00Z",
              "store_path": ".slack_tokens.json"
            }
          }
        }
      }
    }
  }
}

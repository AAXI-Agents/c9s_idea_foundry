{
  "delete": {
    "tags": ["Agent Worker"],
    "summary": "Delete Atlassian credentials",
    "description": "Delete stored Atlassian credentials for an organization. Removes from both local MongoDB and Agent Worker.",
    "operationId": "delete_atlassian_credentials",
    "parameters": [
      {
        "name": "org_id",
        "in": "path",
        "required": true,
        "schema": { "type": "string" },
        "description": "Organization ID whose credentials to delete"
      }
    ],
    "responses": {
      "200": {
        "description": "Credentials deleted",
        "content": {
          "application/json": {
            "schema": {
              "type": "object",
              "properties": {
                "deleted": { "type": "boolean" },
                "agent_worker_deleted": { "type": "boolean" }
              }
            }
          }
        }
      },
      "401": { "$ref": "#/components/responses/Unauthorized" },
      "503": {
        "description": "Agent Worker integration is disabled"
      }
    },
    "security": [{ "BearerAuth": [] }]
  }
}

{
  "post": {
    "tags": ["Agent Worker"],
    "summary": "Test Atlassian credentials",
    "description": "Proxy credential test to Agent Worker. Verifies stored Atlassian credentials can connect to the configured instance.",
    "operationId": "test_atlassian_credentials",
    "parameters": [
      {
        "name": "org_id",
        "in": "path",
        "required": true,
        "schema": { "type": "string" },
        "description": "Organization ID whose credentials to test"
      }
    ],
    "responses": {
      "200": {
        "description": "Test result from Agent Worker",
        "content": {
          "application/json": {
            "schema": {
              "type": "object",
              "properties": {
                "jira_ok": { "type": "boolean" },
                "confluence_ok": { "type": "boolean" },
                "jira_error": { "type": "string", "nullable": true },
                "confluence_error": { "type": "string", "nullable": true }
              }
            }
          }
        }
      },
      "401": { "$ref": "#/components/responses/Unauthorized" },
      "503": {
        "description": "Agent Worker integration is disabled"
      }
    },
    "security": [{ "BearerAuth": [] }]
  }
}

        "name": "project_id",
        "in": "path",
        "required": true,
        "schema": {
          "type": "string",
          "title": "Project Id"
        }
      },
      {
        "name": "limit",
        "in": "query",
        "required": false,
        "schema": {
          "type": "integer",
          "maximum": 1000,
          "minimum": 1,
          "description": "Max items.",
          "default": 200,
          "title": "Limit"
        },
        "description": "Max items."
      }
    ],
    "responses": {
      "200": {
        "description": "Backlog returned successfully.",
        "content": {
          "application/json": {
            "schema": {
              "$ref": "#/components/schemas/BacklogResponse"
            }
          }
        }
      },
      "404": {
        "description": "Project not found."
      },
      "422": {
        "description": "Validation Error",
        "content": {
          "application/json": {
            "schema": {
              "$ref": "#/components/schemas/HTTPValidationError"
            }
          }
        }
      }
    }
  }

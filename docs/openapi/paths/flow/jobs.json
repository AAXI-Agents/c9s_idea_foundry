{
  "get": {
    "summary": "List all persistent job records",
    "description": "Returns job records from the crewJobs MongoDB collection. Each job tracks the full lifecycle of a flow run including queue time, running time, and terminal status. Note: flow errors result in status='paused' (not 'failed'), allowing runs to be resumed.\n\nOptional query parameters 'status' and 'flow_name' can be used to filter results.",
    "operationId": "list_all_jobs_flow_jobs_get",
    "tags": ["Jobs"],
    "parameters": [
      {
        "name": "status",
        "in": "query",
        "required": false,
        "schema": {
          "type": "string"
        }
      },
      {
        "name": "flow_name",
        "in": "query",
        "required": false,
        "schema": {
          "type": "string"
        }
      },
      {
        "name": "limit",
        "in": "query",
        "required": false,
        "schema": {
          "type": "integer",
          "default": 50
        }
      }
    ],
    "responses": {
      "200": {
        "description": "Job list returned successfully.",
        "content": {
          "application/json": {
            "schema": {
              "$ref": "../openapi.json#/components/schemas/JobListResponse"
            }
          }
        }
      },
      "500": {
        "description": "Internal server error (INTERNAL_ERROR).",
        "content": {
          "application/json": {
            "schema": {
              "$ref": "../openapi.json#/components/schemas/ErrorResponse"
            }
          }
        }
      },
      "503": {
        "description": "LLM / OpenAI service unavailable (LLM_ERROR or BILLING_ERROR). The affected flow run is automatically paused.",
        "content": {
          "application/json": {
            "schema": {
              "$ref": "../openapi.json#/components/schemas/ErrorResponse"
            }
          }
        }
      }
    }
  }
}

{
  "get": {
    "summary": "List All Jobs",
    "description": "Returns job records from the crewJobs collection.",
    "operationId": "list_all_jobs_flow_jobs_get",
    "parameters": [
      {
        "name": "status",
        "in": "query",
        "required": false,
        "schema": {
          "type": "string"
        }
      },
      {
        "name": "flow_name",
        "in": "query",
        "required": false,
        "schema": {
          "type": "string"
        }
      },
      {
        "name": "limit",
        "in": "query",
        "required": false,
        "schema": {
          "type": "integer",
          "default": 50
        }
      }
    ],
    "responses": {
      "200": {
        "description": "Job list returned successfully.",
        "content": {
          "application/json": {
            "schema": {
              "$ref": "../openapi.json#/components/schemas/JobListResponse"
            }
          }
        }
      },
      "500": {
        "description": "Internal server error (INTERNAL_ERROR).",
        "content": {
          "application/json": {
            "schema": {
              "$ref": "../openapi.json#/components/schemas/ErrorResponse"
            }
          }
        }
      },
      "503": {
        "description": "LLM / OpenAI service unavailable (LLM_ERROR or BILLING_ERROR). The affected flow run is automatically paused.",
        "content": {
          "application/json": {
            "schema": {
              "$ref": "../openapi.json#/components/schemas/ErrorResponse"
            }
          }
        }
      }
    }
  }
}

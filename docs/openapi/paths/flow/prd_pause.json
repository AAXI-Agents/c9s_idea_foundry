{
  "post": {
    "summary": "Pause and Save Progress",
    "description": "Pause a running PRD flow and save current progress.",
    "operationId": "pause_prd_flow_prd_pause_post",
    "requestBody": {
      "content": {
        "application/json": {
          "schema": {
            "$ref": "../openapi.json#/components/schemas/PRDPauseRequest"
          }
        }
      },
      "required": true
    },
    "responses": {
      "200": {
        "description": "Pause requested successfully.",
        "content": {
          "application/json": {
            "schema": {
              "$ref": "../openapi.json#/components/schemas/PRDActionResponse"
            }
          }
        }
      },
      "404": {
        "description": "Run not found."
      },
      "409": {
        "description": "Run cannot be paused in its current state."
      },
      "422": {
        "description": "Validation Error",
        "content": {
          "application/json": {
            "schema": {
              "$ref": "../openapi.json#/components/schemas/HTTPValidationError"
            }
          }
        }
      },
      "500": {
        "description": "Internal server error (INTERNAL_ERROR).",
        "content": {
          "application/json": {
            "schema": {
              "$ref": "../openapi.json#/components/schemas/ErrorResponse"
            }
          }
        }
      },
      "503": {
        "description": "LLM / OpenAI service unavailable (LLM_ERROR or BILLING_ERROR). The affected flow run is automatically paused.",
        "content": {
          "application/json": {
            "schema": {
              "$ref": "../openapi.json#/components/schemas/ErrorResponse"
            }
          }
        }
      }
    }
  }
}

        "schema": {
          "type": "string",
          "title": "Run Id"
        }
      },
      {
        "name": "limit",
        "in": "query",
        "required": false,
        "schema": {
          "type": "integer",
          "maximum": 1000,
          "minimum": 1,
          "default": 200,
          "title": "Limit"
        }
      }
    ],
    "responses": {

{
  "post": {
    "tags": [
      "Ideation Flow"
    ],
    "summary": "Trigger agent for current step",
    "description": "Recovery endpoint: triggers the agent to generate structured questions for the current step when the auto-trigger on advance failed silently. Returns the agent's response via WebSocket and REST.",
    "operationId": "trigger_ideation_step_flow_ideation_sessions__session_id__trigger_post",
    "parameters": [
      {
        "name": "session_id",
        "in": "path",
        "required": true,
        "schema": {
          "type": "string",
          "title": "Session Id"
        }
      }
    ],
    "responses": {
      "200": {
        "description": "Successful Response",
        "content": {
          "application/json": {
            "schema": {
              "$ref": "#/components/schemas/IdeationRespondResponse"
            }
          }
        }
      },
      "404": {
        "description": "Session not found.",
        "content": {
          "application/json": {
            "schema": {
              "$ref": "#/components/schemas/IdeationErrorResponse"
            }
          }
        }
      },
      "500": {
        "description": "Internal server error.",
        "content": {
          "application/json": {
            "schema": {
              "$ref": "#/components/schemas/IdeationErrorResponse"
            }
          }
        }
      },
      "503": {
        "description": "LLM service unavailable.",
        "content": {
          "application/json": {
            "schema": {
              "$ref": "#/components/schemas/IdeationErrorResponse"
            }
          }
        }
      },
      "422": {
        "description": "Validation Error",
        "content": {
          "application/json": {
            "schema": {
              "$ref": "#/components/schemas/HTTPValidationError"
            }
          }
        }
      }
    }
  }
}
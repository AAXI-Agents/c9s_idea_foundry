{
  "openapi": "3.1.0",
  "info": {
    "title": "CrewAI Product Feature Planner API",
    "description": "HTTP interface for triggering CrewAI flows.",
    "version": "0.1.0"
  },
  "paths": {
    "/health": {
      "get": {
        "summary": "Health",
        "description": "Basic liveness probe.",
        "operationId": "health_health_get",
        "responses": {
          "200": {
            "description": "Successful Response",
            "content": {
              "application/json": {
                "schema": {}
              }
            }
          }
        }
      }
    },
    "/flow/runs/{run_id}": {
      "get": {
        "summary": "Get Run Status",
        "description": "Check the status of a flow run.",
        "operationId": "get_run_status_flow_runs__run_id__get",
        "parameters": [
          {
            "name": "run_id",
            "in": "path",
            "required": true,
            "schema": {
              "type": "string",
              "title": "Run Id"
            }
          }
        ],
        "responses": {
          "200": {
            "description": "Successful Response",
            "content": {
              "application/json": {
                "schema": {}
              }
            }
          },
          "422": {
            "description": "Validation Error",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/HTTPValidationError"
                }
              }
            }
          }
        }
      }
    },
    "/flow/prd/kickoff": {
      "post": {
        "summary": "Kickoff Prd Flow",
        "description": "Trigger the iterative PRD generation flow.\n\nReturns immediately with a ``run_id``. The flow runs until the user\napproves. Poll ``GET /flow/runs/{run_id}`` for status, then call\n``POST /flow/prd/approve`` to finalise.",
        "operationId": "kickoff_prd_flow_flow_prd_kickoff_post",
        "requestBody": {
          "content": {
            "application/json": {
              "schema": {
                "$ref": "#/components/schemas/PRDKickoffRequest"
              }
            }
          },
          "required": true
        },
        "responses": {
          "202": {
            "description": "Successful Response",
            "content": {
              "application/json": {
                "schema": {}
              }
            }
          },
          "422": {
            "description": "Validation Error",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/HTTPValidationError"
                }
              }
            }
          }
        }
      }
    },
    "/flow/prd/approve": {
      "post": {
        "summary": "Approve Prd",
        "description": "Approve or continue refining a PRD run.\n\nWhen ``approve=true`` the current draft becomes the final PRD.\nWhen ``approve=false`` the flow continues with another refinement cycle.",
        "operationId": "approve_prd_flow_prd_approve_post",
        "requestBody": {
          "content": {
            "application/json": {
              "schema": {
                "$ref": "#/components/schemas/PRDApproveRequest"
              }
            }
          },
          "required": true
        },
        "responses": {
          "200": {
            "description": "Successful Response",
            "content": {
              "application/json": {
                "schema": {}
              }
            }
          },
          "422": {
            "description": "Validation Error",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/HTTPValidationError"
                }
              }
            }
          }
        }
      }
    }
  },
  "components": {
    "schemas": {
      "HTTPValidationError": {
        "properties": {
          "detail": {
            "items": {
              "$ref": "#/components/schemas/ValidationError"
            },
            "type": "array",
            "title": "Detail"
          }
        },
        "type": "object",
        "title": "HTTPValidationError"
      },
      "PRDApproveRequest": {
        "properties": {
          "run_id": {
            "type": "string",
            "title": "Run Id",
            "description": "The run to approve or continue."
          },
          "approve": {
            "type": "boolean",
            "title": "Approve",
            "description": "True to finalise the PRD, False to keep refining."
          }
        },
        "type": "object",
        "required": [
          "run_id",
          "approve"
        ],
        "title": "PRDApproveRequest",
        "description": "Request body for POST /flow/prd/approve."
      },
      "PRDKickoffRequest": {
        "properties": {
          "idea": {
            "type": "string",
            "minLength": 1,
            "title": "Idea",
            "description": "The product feature idea to build a PRD for."
          }
        },
        "type": "object",
        "required": [
          "idea"
        ],
        "title": "PRDKickoffRequest",
        "description": "Request body for POST /flow/prd/kickoff."
      },
      "ValidationError": {
        "properties": {
          "loc": {
            "items": {
              "anyOf": [
                {
                  "type": "string"
                },
                {
                  "type": "integer"
                }
              ]
            },
            "type": "array",
            "title": "Location"
          },
          "msg": {
            "type": "string",
            "title": "Message"
          },
          "type": {
            "type": "string",
            "title": "Error Type"
          },
          "input": {
            "title": "Input"
          },
          "ctx": {
            "type": "object",
            "title": "Context"
          }
        },
        "type": "object",
        "required": [
          "loc",
          "msg",
          "type"
        ],
        "title": "ValidationError"
      }
    }
  }
}

# Example environment variables for crewai_productfeature_planner
# Copy this file to `.env` and fill in real values locally.
# ─────────────────────────────────────────────────────────────

# ── Environment & Domain ───────────────────────────────────────
# SERVER_ENV determines which domain the app uses for OAuth callbacks,
# webhook URLs, and public-facing links.
#   DEV  — local development: starts ngrok tunnel (requires NGROK_AUTHTOKEN)
#   UAT  — staging / user-acceptance: uses DOMAIN_NAME_UAT (no tunnel)
#   PROD — production: uses DOMAIN_NAME_PROD (no tunnel)
SERVER_ENV=DEV
# Domain names for UAT and PROD (ignored in DEV).
# Do NOT include the scheme — https:// is added automatically.
DOMAIN_NAME_UAT=
DOMAIN_NAME_PROD=

# ── LLM Provider (required) ──────────────────────────────────
# CrewAI model selector — see https://docs.crewai.com/concepts/llms
# Basic OpenAI model — intent classification, basic-tier section drafting
OPENAI_MODEL=gpt-4.1-mini
# Research OpenAI model — PRD section drafting, deep reasoning
OPENAI_RESEARCH_MODEL=o3
OPENAI_API_KEY=

# ── Default Agent ─────────────────────────────────────────────
# Which LLM provider to use as the primary backend.
# Valid values: openai, gemini
DEFAULT_AGENT=gemini

# ── Multi-Agent Parallel Drafting ──────────────────────────────
# How many PM agents to run in parallel for section drafting.
# 1 = default agent only (fast, single-provider).
DEFAULT_MULTI_AGENTS=1

# ── Google Gemini (required for Idea Refinement & Requirements Breakdown) ──
# Enables Gemini-powered agents for idea refinement and requirements
# breakdown phases. Set at least one of the auth modes below.
#
# Two auth modes — set at least one:
#   A) API key  — get one at https://aistudio.google.com/apikey
#   B) Vertex AI — set GOOGLE_CLOUD_PROJECT and run:
#                  gcloud auth application-default login
#      Or set GOOGLE_APPLICATION_CREDENTIALS to a service-account JSON.
#      If both are set, the API key takes precedence.
#
# See https://ai.google.dev/gemini-api/docs/quickstart
GOOGLE_API_KEY=
GOOGLE_CLOUD_PROJECT=
GOOGLE_CLOUD_LOCATION=asia-southeast1
# Override the Gemini model (default: gemini-3-flash-preview)
# See available models at https://cloud.google.com/vertex-ai/generative-ai/docs/learn/models
GEMINI_MODEL=gemini-3-flash-preview
# Research Gemini model — PRD section drafting, deep reasoning
GEMINI_RESEARCH_MODEL=gemini-3.1-pro-preview

# ── Idea Refinement Agent ──────────────────────────────────────
# Gemini-powered agent that enriches raw ideas before PRD generation.
# Automatically enabled when GOOGLE_API_KEY or GOOGLE_CLOUD_PROJECT is set.
# Minimum self-refinement iterations (default: 3)
IDEA_REFINER_MIN_ITERATIONS=3
# Maximum self-refinement iterations (default: 10)
IDEA_REFINER_MAX_ITERATIONS=10
# Override the model (defaults to GEMINI_MODEL)
# IDEA_REFINER_MODEL=gemini-3-flash-preview

# ── Requirements Breakdown Agent ───────────────────────────────
# Gemini-powered agent that decomposes refined ideas into product requirements.
# Minimum breakdown iterations (default: 3)
REQUIREMENTS_BREAKDOWN_MIN_ITERATIONS=3
# Maximum breakdown iterations (default: 10)
REQUIREMENTS_BREAKDOWN_MAX_ITERATIONS=10
# Override the model (defaults to GEMINI_MODEL)
# REQUIREMENTS_BREAKDOWN_MODEL=gemini-3-flash-preview

# ── PRD Section Iterations ─────────────────────────────────────
# Controls critique→refine loops for each PRD section (Phase 1 & 2).
# Minimum iterations before auto-approve is possible (default: 2)
PRD_SECTION_MIN_ITERATIONS=2
# Maximum iterations per section (default: 10)
PRD_SECTION_MAX_ITERATIONS=10

# ── LLM Timeout & Retry ──────────────────────────────────────
# Request timeout in seconds (default 300 — generous for reasoning models)
LLM_TIMEOUT=300
# Number of retries on transient LLM errors (default 3)
LLM_MAX_RETRIES=3
# Base delay in seconds for exponential back-off between retries (default 5)
LLM_RETRY_BASE_DELAY=5

# ── Search & Research Tools (required) ────────────────────────
# SerperDevTool — Google search for market & competitor research
# Get a free key at https://serper.dev
SERPER_API_KEY=

# ── MongoDB Atlas ──────────────────────────────────────────────
# Full mongodb+srv:// connection string (required)
# Get one from https://cloud.mongodb.com → Database → Connect
MONGODB_ATLAS_URI=
# Database name — change this to point at a different database
# (e.g. ideas_uat, ideas_prod, ideas_dev)
MONGODB_DB=ideas

# ── Slack Integration ──────────────────────────────────────────
# Required for Slack Events API and Interactivity webhooks.
# Create a Slack app from slack_manifest.json to obtain these values.
SLACK_SIGNING_SECRET=
SLACK_CLIENT_ID=
SLACK_CLIENT_SECRET=
# Bot token — auto-populated after OAuth install, or set manually.
# For dev setup without OAuth, set SLACK_BOT_TOKEN from
# https://api.slack.com/apps/<app-id>/oauth → Bot User OAuth Token (xoxb-…)
SLACK_BOT_TOKEN=
SLACK_ACCESS_TOKEN=
# Refresh token for rotating tokens (auto-populated after exchange)
SLACK_REFRESH_TOKEN=
# Deprecated fallback for request verification (use SLACK_SIGNING_SECRET instead)
# SLACK_VERIFICATION_TOKEN=
# Default channel for posting results (default: crewai-prd-planner)
SLACK_DEFAULT_CHANNEL=crewai-prd-planner
# Path to JSON file for persisting rotated tokens (default: .slack_tokens.json)
# SLACK_TOKEN_STORE=.slack_tokens.json
# Set to "1" or "true" to enable dry-run mode (skip actual Slack API calls)
# SLACK_BYPASS=false

# App ID and configuration token — enable automatic Slack app URL updates
# when the ngrok tunnel restarts.  Without these the server prints manual
# instructions instead.
# Find the App ID in Basic Information at https://api.slack.com/apps
SLACK_APP_ID=
# App-configuration token (xoxe.xoxp-…) — create one at
# https://api.slack.com/apps/<app-id>/app-level-tokens with
# app_management:write scope.
SLACK_APP_CONFIGURATION_TOKEN=

# ── Ngrok (remote access) ─────────────────────────────────────
# Auth token from https://dashboard.ngrok.com/get-started/your-authtoken
NGROK_AUTHTOKEN=
# Optional: stable ngrok domain so the URL stays the same across restarts.
# Free tier includes one static domain — claim one at
# https://dashboard.ngrok.com/domains  (e.g. myapp.ngrok-free.dev)
NGROK_DOMAIN=

# ── Telemetry ─────────────────────────────────────────────────
# Set to true to disable CrewAI telemetry phone-home requests
CREWAI_TELEMETRY_OPT_OUT=true

# ── Logging ───────────────────────────────────────────────────
# Set to true to enable DEBUG-level messages in the log file
CREWAI_DEBUG=true
# Set to true to also stream flow-execution logs to the console
CREWAI_FLOW_DEBUG=false
# Number of daily log files to retain (default 7)
CREWAI_LOG_RETENTION_DAYS=7
# Set to true to enable verbose CrewAI agent/crew console output (default false)
CREWAI_VERBOSE=false

# ── Atlassian (shared by Confluence & Jira) ────────────────────────
# Get an API token at: https://id.atlassian.com/manage-profile/security/api-tokens
ATLASSIAN_BASE_URL=
ATLASSIAN_USERNAME=
ATLASSIAN_API_TOKEN=

# ── Confluence ─────────────────────────────────────────────────────
# Fallback space key used when no project-level key is configured.
# Project-level confluence_space_key (stored in MongoDB projectConfig)
# takes priority at runtime.
CONFLUENCE_SPACE_KEY=
# Fallback parent page ID — same override logic as CONFLUENCE_SPACE_KEY.
CONFLUENCE_PARENT_ID=

# ── Jira ───────────────────────────────────────────────────────────
# Fallback project key used when no project-level key is configured.
# Project-level jira_project_key (stored in MongoDB projectConfig)
# takes priority at runtime.
JIRA_PROJECT_KEY=

# ── Figma Make (UX Design) ─────────────────────────────────────
# Required for automatic design generation via the UX Designer agent.
# Personal access token — create one at:
# https://www.figma.com/developers/api#access-tokens
FIGMA_ACCESS_TOKEN=
# Team ID — designs are created in this team's drafts.
# Find it in the Figma URL: https://www.figma.com/files/team/<TEAM_ID>/...
FIGMA_TEAM_ID=
# Override the Gemini model for the UX Designer agent (defaults to GEMINI_MODEL)
# GEMINI_UX_DESIGNER_MODEL=gemini-3-flash-preview

# ── Orchestrator Agent ─────────────────────────────────────────
# Override the Gemini model for the orchestrator agent (defaults to GEMINI_MODEL)
# ORCHESTRATOR_MODEL=gemini-3-flash-preview

# ── SSO Authentication (C9 Single Sign-On) ────────────────────
# Set SSO_ENABLED=true to enforce Bearer-token auth on API endpoints.
# When false (default) all endpoints accept unauthenticated requests.
SSO_ENABLED=false

# Base URL of the SSO service (for remote token introspection).
SSO_BASE_URL=http://localhost:8100

# \u2500\u2500 OAuth client credentials \u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500
# Required for /auth/sso/* login, register, and callback endpoints.
# Obtain from the SSO admin dashboard (/sso/apps).
SSO_CLIENT_ID=
SSO_CLIENT_SECRET=

# \u2500\u2500 RS256 public key \u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500
# Path to the RSA public key used to verify SSO JWT tokens locally.
# When not set, falls back to remote introspection via SSO_BASE_URL.
SSO_JWT_PUBLIC_KEY_PATH=

# Issuer claim expected in JWT tokens (must match SSO_ISSUER on the SSO server).
SSO_ISSUER=c9s-sso

# \u2500\u2500 Application identity \u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500
# When set, tokens must carry this app_id claim (from OAuth auth-code flow).
# Leave empty to accept any valid SSO token regardless of target application.
# Obtain from the SSO admin dashboard (/sso/apps) or bootstrap logs.
SSO_EXPECTED_APP_ID=

# \u2500\u2500 Webhook verification \u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500
# HMAC-SHA256 secret for verifying inbound SSO webhook payloads.
# Must match the secret configured in the SSO webhook subscription.
SSO_WEBHOOK_SECRET=

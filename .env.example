# Example environment variables for crewai_productfeature_planner
# Copy this file to `.env` and fill in real values locally.
# ─────────────────────────────────────────────────────────────

# ── LLM Provider (required) ──────────────────────────────────
# CrewAI model selector — see https://docs.crewai.com/concepts/llms
OPENAI_MODEL=o3
OPENAI_API_KEY=

# ── Default Agent ─────────────────────────────────────────────
# Which agent to use as the primary LLM for all tasks.
# Valid values: openai_pm
# The default agent is always required.
DEFAULT_AGENT=gemini_pm

# ── Multi-Agent Parallel Drafting ──────────────────────────────
# How many PM agents to run in parallel for section drafting.
# 1 = default agent only (fast, single-provider).
DEFAULT_MULTI_AGENTS=1

# ── Google Gemini (required for Idea Refinement & Requirements Breakdown) ──
# Enables Gemini-powered agents for idea refinement and requirements
# breakdown phases. Set at least one of the auth modes below.
#
# Two auth modes — set at least one:
#   A) API key  — get one at https://aistudio.google.com/apikey
#   B) Vertex AI — set GOOGLE_CLOUD_PROJECT and run:
#                  gcloud auth application-default login
#      Or set GOOGLE_APPLICATION_CREDENTIALS to a service-account JSON.
#      If both are set, the API key takes precedence.
#
# See https://ai.google.dev/gemini-api/docs/quickstart
GOOGLE_API_KEY=
GOOGLE_CLOUD_PROJECT=
GOOGLE_CLOUD_LOCATION=asia-southeast1
# Override the Gemini model (default: gemini-3-flash-preview)
# See available models at https://cloud.google.com/vertex-ai/generative-ai/docs/learn/models
GEMINI_MODEL=gemini-3-flash-preview

# ── Idea Refinement Agent ──────────────────────────────────────
# Gemini-powered agent that enriches raw ideas before PRD generation.
# Automatically enabled when GOOGLE_API_KEY or GOOGLE_CLOUD_PROJECT is set.
# Minimum self-refinement iterations (default: 3)
IDEA_REFINER_MIN_ITERATIONS=3
# Maximum self-refinement iterations (default: 10)
IDEA_REFINER_MAX_ITERATIONS=10
# Override the model (defaults to GEMINI_MODEL)
# IDEA_REFINER_MODEL=gemini-3-flash-preview

# ── Requirements Breakdown Agent ───────────────────────────────
# Gemini-powered agent that decomposes refined ideas into product requirements.
# Minimum breakdown iterations (default: 3)
REQUIREMENTS_BREAKDOWN_MIN_ITERATIONS=3
# Maximum breakdown iterations (default: 10)
REQUIREMENTS_BREAKDOWN_MAX_ITERATIONS=10
# Override the model (defaults to GEMINI_MODEL)
# REQUIREMENTS_BREAKDOWN_MODEL=gemini-3-flash-preview

# ── PRD Section Iterations ─────────────────────────────────────
# Controls critique→refine loops for each PRD section (Phase 1 & 2).
# Minimum iterations before auto-approve is possible (default: 2)
PRD_SECTION_MIN_ITERATIONS=2
# Maximum iterations per section (default: 10)
PRD_SECTION_MAX_ITERATIONS=10

# ── LLM Timeout & Retry ──────────────────────────────────────
# Request timeout in seconds (default 300 — generous for reasoning models)
LLM_TIMEOUT=300
# Number of retries on transient LLM errors (default 3)
LLM_MAX_RETRIES=3
# Base delay in seconds for exponential back-off between retries (default 5)
LLM_RETRY_BASE_DELAY=5

# ── Search & Research Tools (required) ────────────────────────
# SerperDevTool — Google search for market & competitor research
# Get a free key at https://serper.dev
SERPER_API_KEY=

# ── MongoDB ────────────────────────────────────────────────────
# Host (default: localhost)
MONGODB_URI=localhost
# Port (default: 27017)
MONGODB_PORT=27017
# Database name (default: ideas)
MONGODB_DB=ideas
# Optional — leave blank for local dev without auth
MONGODB_USERNAME=
MONGODB_PASSWORD=

# ── Ngrok (remote access) ─────────────────────────────────────
# Auth token from https://dashboard.ngrok.com/get-started/your-authtoken
NGROK_AUTHTOKEN=

# ── Telemetry ─────────────────────────────────────────────────
# Set to true to disable CrewAI telemetry phone-home requests
CREWAI_TELEMETRY_OPT_OUT=true

# ── Logging ───────────────────────────────────────────────────
# Set to true to enable DEBUG-level messages in the log file
CREWAI_DEBUG=true
# Set to true to also stream flow-execution logs to the console
CREWAI_FLOW_DEBUG=false
# Number of daily log files to retain (default 7)
CREWAI_LOG_RETENTION_DAYS=7
# Set to true to enable verbose CrewAI agent/crew console output (default false)
CREWAI_VERBOSE=false

# ── Atlassian Confluence ───────────────────────────────────────
# Required for automatic PRD publishing to Confluence.
# Get an API token at: https://id.atlassian.com/manage-profile/security/api-tokens
CONFLUENCE_BASE_URL=
CONFLUENCE_SPACE_KEY=
CONFLUENCE_USERNAME=
CONFLUENCE_API_TOKEN=
# Optional — parent page ID to nest new PRD pages under
CONFLUENCE_PARENT_ID=

# ── Atlassian Jira ─────────────────────────────────────────────
# Required for automatic Jira ticket creation from PRD requirements.
JIRA_BASE_URL=
JIRA_PROJECT_KEY=
JIRA_USERNAME=
JIRA_API_TOKEN=

# ── Orchestrator Agent ─────────────────────────────────────────
# Override the Gemini model for the orchestrator agent (defaults to GEMINI_MODEL)
# ORCHESTRATOR_MODEL=gemini-3-flash-preview
